{
  "profileName": "Warzone — Precision Aim",
  "version": "2.0",
  "description": "Perfil otimizado para Warzone: curva de aceleração multi-ponto, decay lento, precisão cirúrgica em micro-aim",

  "mouse": {
    "sensitivityX": 3.5,
    "sensitivityY": 3.5,

    "exponent": 1.3,

    "accelCurve": [
      { "speed": 0,   "mult": 0.12 },
      { "speed": 3,   "mult": 0.20 },
      { "speed": 8,   "mult": 0.38 },
      { "speed": 20,  "mult": 0.65 },
      { "speed": 40,  "mult": 0.85 },
      { "speed": 70,  "mult": 1.00 }
    ],

    "maxSpeed": 1.0,

    "deadzone": 0.0,
    "jitterThreshold": 0.5,

    "smoothSamples": 3,

    "decayDelay": 0.0,
    "decayRate": 0.0,
    "decayMinStick": 0.0,

    "normalizeVector": true,
    "target": "rightStick"
  },

  "keyBindings": {
    "87":  { "target": "leftStickY", "axisValue": 1.0,  "label": "W → LS Up" },
    "83":  { "target": "leftStickY", "axisValue": -1.0, "label": "S → LS Down" },
    "65":  { "target": "leftStickX", "axisValue": -1.0, "label": "A → LS Left" },
    "68":  { "target": "leftStickX", "axisValue": 1.0,  "label": "D → LS Right" },

    "32":  { "target": "button", "mask": 4096,  "label": "Space → A (Jump)" },
    "17":  { "target": "button", "mask": 8192,  "label": "Ctrl → B (Crouch/Slide)" },
    "16":  { "target": "button", "mask": 16384, "label": "Shift → X (Sprint/Tac Sprint)" },

    "70":  { "target": "button", "mask": 32768, "label": "F → Y (Use/Interact)" },
    "82":  { "target": "rightTrigger", "axisValue": 1.0, "label": "R → RT (Reload)" },
    "71":  { "target": "leftTrigger",  "axisValue": 1.0, "label": "G → LT (Lethal)" },

    "81":  { "target": "button", "mask": 256,   "label": "Q → LB (Tactical)" },
    "69":  { "target": "button", "mask": 512,   "label": "E → RB (Mount/Lean)" },

    "9":   { "target": "button", "mask": 16,    "label": "Tab → Back (Scoreboard)" },
    "27":  { "target": "button", "mask": 32,    "label": "Esc → Start (Menu)" }
  },

  "mouseBindings": {
    "0": { "target": "rightTrigger", "axisValue": 1.0, "label": "LMB → RT (Fire)" },
    "1": { "target": "leftTrigger",  "axisValue": 1.0, "label": "RMB → LT (ADS)" },
    "2": { "target": "button", "mask": 128, "label": "MMB → RS Click (Melee)" },
    "3": { "target": "button", "mask": 64,  "label": "Mouse X1 → LS Click (Sprint)" },
    "4": { "target": "button", "mask": 32768, "label": "Mouse X2 → Y (Use)" }
  }
}
