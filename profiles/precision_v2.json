{
  "profileName": "FPS - Precision / Sniper (v2)",
  "version": "2.0",
  "description": "Perfil de precisão com sensibilidade baixa e curva suave para mira fina",

  "mouse": {
    "comment": "Configuração precisa com resposta suave",

    "sensitivityX": 1.5,
    "sensitivityY": 1.5,
    "exponent": 1.3,
    "minCurveThreshold": 0.12,

    "maxSpeed": 0.8,
    "acceleration": 6.0,
    "deceleration": 10.0,

    "deadzone": 0.02,
    "jitterThreshold": 0.5,

    "smoothSamples": 5,
    "smoothFactor": 0.4,

    "decayDelay": 150.0,
    "decayRate": 4.0,

    "normalizeVector": true,
    "independentAxes": false,

    "target": "rightStick"
  },

  "keyBindings": {
    "87":  { "target": "leftStickY", "axisValue": 1.0,  "label": "W → LS Up" },
    "83":  { "target": "leftStickY", "axisValue": -1.0, "label": "S → LS Down" },
    "65":  { "target": "leftStickX", "axisValue": -1.0, "label": "A → LS Left" },
    "68":  { "target": "leftStickX", "axisValue": 1.0,  "label": "D → LS Right" },
    "32":  { "target": "button", "mask": 4096,  "label": "Space → A" },
    "17":  { "target": "button", "mask": 8192,  "label": "Ctrl → B" },
    "16":  { "target": "button", "mask": 16384, "label": "Shift → X" },
    "82":  { "target": "rightTrigger", "axisValue": 1.0, "label": "R → RT" }
  },

  "mouseBindings": {
    "0": { "target": "rightTrigger", "axisValue": 1.0, "label": "LMB → RT" },
    "1": { "target": "leftTrigger",  "axisValue": 1.0, "label": "RMB → LT" },
    "3": { "target": "button", "mask": 32768, "label": "Mouse X1 → Y" },
    "4": { "target": "button", "mask": 4096,  "label": "Mouse X2 → A" }
  }
}
